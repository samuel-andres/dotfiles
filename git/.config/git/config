[init]
	defaultBranch = main
[cola]
	theme = flat-dark-blue
	icontheme = dark
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[commit]
    gpgsign = true
[tag]
    gpgsign = true
[merge]
	tool = nvimdiff
[mergetool "nvimdiff"]
	layout = LOCAL,BASE,REMOTE / MERGED
[mergetool]
	keepBackup = false
