" qutebrowser-style bindings

" o - open URL
bind o fillcmdline open

" O - open URL in new tab
bind O fillcmdline tabopen

" go - edit current URL
bind go current_url open

" yy - yank URL to clipboard
bind yy clipboard yank

" HJKL - history/tab nav like qutebrowser
bind H back
bind J tabnext
bind K tabprev
bind L forward

" Quickmarks - :open yt / :tabopen yt etc.
set searchurls.yt https://www.youtube.com/
set searchurls.wh https://web.whatsapp.com/
set searchurls.tw https://x.com/
set searchurls.x https://x.com/
set searchurls.gh https://github.com/
set searchurls.rd https://www.reddit.com/
set searchurls.gm https://mail.google.com/mail/u/0/#inbox
set searchurls.pr https://mail.proton.me/
set searchurls.lb https://letterboxd.com/
set searchurls.gr https://www.goodreads.com/
set searchurls.cb https://codeberg.org/
set searchurls.ml https://www.mercadolibre.com.ar/

" Force normal mode 
set allowautofocus false
